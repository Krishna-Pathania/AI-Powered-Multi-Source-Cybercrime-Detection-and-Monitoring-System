{
  "manifest_version": 3,
  "name": "Cybercrime Detection Guard",
  "version": "1.0.0",
  "description": "Real-time browser security extension powered by the AI-based cybercrime detection backend.",
  "permissions": ["tabs", "storage", "activeTab"],
  "host_permissions": ["http://localhost:5000/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Cybercrime Detection Guard",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
